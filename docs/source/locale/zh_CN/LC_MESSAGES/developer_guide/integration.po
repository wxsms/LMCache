msgstr "LMCache 目前支持与以下内容集成："

#: ../../source/developer_guide/integration.rst:16
msgid "**vLLM**"
msgstr "**vLLM**"

#: ../../source/developer_guide/integration.rst:17
msgid "**SGLang**"
msgstr "**SGLang**"


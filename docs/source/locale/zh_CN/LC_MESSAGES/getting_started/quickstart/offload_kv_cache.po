msgstr "``LMCACHE_CONFIG_FILE``: LMCache 配置文件的路径。"

#: ../../source/getting_started/quickstart/offload_kv_cache.rst:130
msgid "``--kv-transfer-config``: Configures LMCache integration"
msgstr "``--kv-transfer-config``: 配置 LMCache 集成"

#: ../../source/getting_started/quickstart/offload_kv_cache.rst:131
msgid "``kv_connector``: Specifies the LMCache connector"
msgstr "``kv_connector``: 指定 LMCache 连接器"


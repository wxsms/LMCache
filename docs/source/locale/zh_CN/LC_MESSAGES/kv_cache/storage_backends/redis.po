#: ../../source/kv_cache/storage_backends/redis.rst:317
msgid "`model_name`: Name of the language model"
msgstr "`model_name`: 语言模型的名称"

#: ../../source/kv_cache/storage_backends/redis.rst:318
msgid "`world_size`: Total number of workers in distributed deployment"
msgstr "`world_size`: 分布式部署中工作节点的总数"

#: ../../source/kv_cache/storage_backends/redis.rst:319
msgid ""

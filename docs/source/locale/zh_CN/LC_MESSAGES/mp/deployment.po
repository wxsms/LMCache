msgid "**Step 1: Create namespace**"
msgstr "**步骤 1：创建命名空间**"

#: ../../source/mp/deployment.rst:83
msgid "**Step 2: Deploy LMCache DaemonSet**"
msgstr "**步骤 2：部署 LMCache DaemonSet**"

#: ../../source/mp/deployment.rst:89

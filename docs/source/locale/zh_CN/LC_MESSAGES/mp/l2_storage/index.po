msgstr "``--eviction-trigger-watermark``"

#: ../../source/mp/l2_storage/index.rst:184
#: ../../source/mp/l2_storage/index.rst:224
msgid "``0.8``"
msgstr "``0.8``"

#: ../../source/mp/l2_storage/index.rst:185
msgid "L1 usage fraction [0, 1] above which eviction is triggered."
msgstr "触发逐出的 L1 使用比例 [0, 1]。"

#: ../../source/mp/l2_storage/index.rst:186
